# ============================================
# Force HTTPS
# ============================================
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ============================================
# Redirection www vers sans-www
# ============================================
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# ============================================
# URLs propres (sans .html)
# ============================================
# 1. Redirige /foo.html → /foo (301, preserve query string)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ============================================
# URLs WordPress historiques (préservation SEO)
# ============================================

# Anciennes catégories d'acteurs : /acteurs-X → /activites?cat=X (301)
RewriteRule ^acteurs-commerces/?$ /activites?cat=commerces [L,R=301]
RewriteRule ^acteurs-restaurants/?$ /activites?cat=restaurants [L,R=301]
RewriteRule ^acteurs-createurs/?$ /activites?cat=createurs [L,R=301]
RewriteRule ^acteurs-entreprises/?$ /activites?cat=entreprises [L,R=301]
RewriteRule ^acteurs-services/?$ /activites?cat=services [L,R=301]
RewriteRule ^acteurs-sport/?$ /activites?cat=sport [L,R=301]
RewriteRule ^acteurs-sante-soins/?$ /activites?cat=sante [L,R=301]
RewriteRule ^acteurs-coworking/?$ /activites [L,R=301]

# Pages renommées
RewriteRule ^fastlink/?$ /regie-vib [L,R=301]
RewriteRule ^les-services/?$ /services [L,R=301]

# /entreprise?slug=X → /acteur/X (301, URL canonique propre)
RewriteCond %{THE_REQUEST} \s/+entreprise\?slug=([a-z0-9\-]+)\s [NC]
RewriteRule ^ /acteur/%1? [R=301,L]

# /local?slug=X → /local/X (301)
RewriteCond %{THE_REQUEST} \s/+local\?slug=([a-z0-9\-]+)\s [NC]
RewriteRule ^ /local/%1? [R=301,L]

# /article?slug=X → /X (301, articles au root)
RewriteCond %{THE_REQUEST} \s/+article\?slug=([a-z0-9\-]+)\s [NC]
RewriteRule ^ /%1? [R=301,L]

# /acteur/<slug> → entreprise.html?slug=<slug> (rewrite silencieux)
RewriteRule ^acteur/([a-z0-9\-]+)/?$ /entreprise.html?slug=$1 [L,QSA]

# /local/<slug> → local.html?slug=<slug>
RewriteRule ^local/([a-z0-9\-]+)/?$ /local.html?slug=$1 [L,QSA]

# Articles au root : liste explicite des slugs
RewriteRule ^(gros-plan-sur-le-quartier-iraty-de-biarritz-et-son-marche-immobilier|le-forum-des-associations-de-biarritz-de-retour-a-la-halle-diraty|pourquoi-de-plus-en-plus-de-professionnels-sinstallent-en-zone-dactivites|5-astuces-pour-bien-choisir-son-local-commercial|les-erreurs-a-eviter-lors-de-la-location-dun-local-commercial|les-meilleurs-endroits-pour-une-viree-shopping-a-biarritz|la-location-dun-local-commercial-a-biarritz)/?$ /article.html?slug=$1 [L,QSA]

# 2. Sert /foo en lisant /foo.html en interne (pour les pages restantes)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{DOCUMENT_ROOT}/$1.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# ============================================
# Pages d'erreur personnalisées
# ============================================
ErrorDocument 404 /404.html

# ============================================
# Compression Gzip
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xml+rss
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/ttf
    AddOutputFilterByType DEFLATE font/otf
    AddOutputFilterByType DEFLATE font/woff
    AddOutputFilterByType DEFLATE font/woff2
</IfModule>

# ============================================
# Cache navigateur
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On

    # HTML : 1 heure
    ExpiresByType text/html "access plus 1 hour"

    # CSS et JS : 1 mois
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Images : 1 an
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # Fonts : 1 an
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# ============================================
# Headers de sécurité
# ============================================
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ============================================
# Interdiction d'accès aux fichiers sensibles
# ============================================
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

<FilesMatch "\.(env|log|bak|old|swp|sql|md|yml|yaml|gitignore|htaccess|htpasswd)$">
    Require all denied
</FilesMatch>

# Les .json dans data/ sont du contenu legitime servi au frontend (acteurs,
# articles, locaux). On autorise explicitement leur acces en lecture.

<Files ".cpanel.yml">
    Require all denied
</Files>

<Files "CLAUDE.md">
    Require all denied
</Files>

# ============================================
# Bloquer l'accès direct au dossier vendor
# ============================================
RedirectMatch 403 ^/vendor(/|$)

# ============================================
# Désactiver listing des répertoires
# ============================================
Options -Indexes

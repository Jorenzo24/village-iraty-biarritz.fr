# ============================================
# VIB — Configuration SMTP (template)
# ============================================
# Copier ce fichier en .env et remplir les valeurs.
# Le fichier .env est ignoré par Git (voir .gitignore).
# Sur cPanel : déposer le .env dans /home/villageiratybiar/public_html/

SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=noreply@example.com
SMTP_PASS=replace_me
SMTP_FROM=noreply@example.com
SMTP_FROM_NAME="VILLAGE Iraty-Biarritz"
SMTP_TO=contact@example.com
SMTP_TO_NAME="Contact VIB"
